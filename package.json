{
  "name": "catalog-migration-tool",
  "description": "Migrate product catalog and inventory data into Treez",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@webext-core/fake-browser": "^1.3.4",
    "@webext-core/messaging": "^1.4.0",
    "@wxt-dev/module-react": "^1.1.3",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18",
    "wxt": "^0.20.18"
  }
}
